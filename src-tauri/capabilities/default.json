{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window and reader windows",
  "windows": ["main", "reader-*"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:webview:default",
    "core:webview:allow-create-webview-window",
    "core:event:default",
    "core:path:default",
    "dialog:default",
    "opener:allow-open-url",
    "updater:default",
    "process:default",
    "process:allow-restart"
  ]
}
